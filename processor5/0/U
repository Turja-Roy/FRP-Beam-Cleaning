        type            pressureInletVelocity;
        value           uniform (0 0 0);
    }
    beamHoles
    {
        type            pressureInletOutletVelocity;
        value           uniform (0 0 0);
    }
    procBoundary5to0
    {
        type            processor;
        value           uniform (0 0 0);
    }
    procBoundary5to1
    {
        type            processor;
        value           uniform (0 0 0);
    }
    procBoundary5to2
    {
        type            processor;
