    {
        type            zeroGradient;
    }
    beamFrontOpening
    {
        type            waveTransmissive;
        gamma           1.4;
        fieldInf        101325;
        lInf            1;
        value           nonuniform List<scalar> 
0
;
    }
    beamBackOpening
    {
        type            totalPressure;
        rho             rho;
        psi             none;
        gamma           1;
        p0              uniform 482633;
        value           uniform 482633;
    }
    beamHoles
    {
        type            waveTransmissive;
        gamma           1.4;
        fieldInf        101325;
        lInf            1;
        value           uniform 101325;
    }
    procBoundary5to0
