FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      alphat;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// Turbulent thermal diffusivity (alphat = nut / Prt)
// Prt (turbulent Prandtl number) typically ~0.85 for air

dimensions      [1 -1 -1 0 0 0 0];  // kg/(m*s)

internalField   uniform 0;

boundaryField
{
    beamWalls
    {
        type            compressible::alphatWallFunction;
        Prt             0.85;
        value           uniform 0;
    }
    
    beamFrontOpening
    {
        type            calculated;
        value           uniform 0;
    }
    
    beamBackOpening
    {
        type            calculated;
        value           uniform 0;
    }
    
    beamHoles
    {
        type            calculated;
        value           uniform 0;
    }
    
    enclosure
    {
        type            calculated;
        value           uniform 0;
    }
}

