#!/bin/bash
# Simple mesh generation script

cd "$(dirname "$0")/.." || exit 1

echo "Starting mesh generation..."
echo "Case: $(pwd)"
echo ""

# Clean old mesh
echo "Cleaning old mesh..."
rm -rf constant/polyMesh constant/extendedFeatureEdgeMesh processor* [1-9]*
echo ""

# Create log directory
LOGDIR="logs/mesh_$(date +%Y%m%d_%H%M%S)"
mkdir -p "$LOGDIR"

# Background mesh
echo "Running blockMesh..."
blockMesh > "$LOGDIR/log.blockMesh" 2>&1
if [ $? -ne 0 ]; then
    echo "ERROR: blockMesh failed"
    exit 1
fi
echo "✓ blockMesh done"
echo ""

# Extract features
echo "Extracting features..."
surfaceFeatures > "$LOGDIR/log.surfaceFeatures" 2>&1
echo "✓ Features done"
echo ""

# Decompose for parallel snappyHexMesh
echo "Decomposing for parallel meshing (12 cores)..."
cp system/decomposeParDict.mesh system/decomposeParDict
decomposePar -copyZero > "$LOGDIR/log.decomposePar" 2>&1
if [ $? -ne 0 ]; then
    echo "ERROR: decomposePar failed"
    exit 1
fi
echo "✓ Decomposed"
echo ""

# Run snappyHexMesh in parallel
echo "Running snappyHexMesh in parallel..."
if command -v ibrun &> /dev/null; then
    ibrun snappyHexMesh -parallel -overwrite > "$LOGDIR/log.snappyHexMesh" 2>&1
else
    mpirun -np 12 snappyHexMesh -parallel -overwrite > "$LOGDIR/log.snappyHexMesh" 2>&1
fi
echo "✓ snappyHexMesh done"
echo ""

# Reconstruct
echo "Reconstructing mesh..."
reconstructPar -constant > "$LOGDIR/log.reconstructPar" 2>&1
if [ $? -ne 0 ]; then
    echo "ERROR: reconstructPar failed"
    exit 1
fi
echo "✓ Reconstructed"
echo ""

# Cleanup
echo "Cleaning up..."
rm -rf processor*
cp system/decomposeParDict system/decomposeParDict.mesh.used
echo "✓ Cleanup done"
echo ""

# Check mesh
echo "Checking mesh quality..."
checkMesh > "$LOGDIR/log.checkMesh" 2>&1
if grep -q "Mesh OK" "$LOGDIR/log.checkMesh"; then
    echo "✓ Mesh OK"
else
    echo "WARNING: Mesh has issues, check log"
fi
echo ""

echo "Mesh generation complete!"
echo "Logs: $LOGDIR"
